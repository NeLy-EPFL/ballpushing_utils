# ballpushing_utils environment variables
#
# Copy this file to `.env` and set the paths appropriate for your machine.
# Any script using `ballpushing_utils.paths` will pick these up when it calls
# `load_dotenv()`, or you can `export` them in your shell.

# Root directory containing datasets (feathers, videos, region maps, ...).
# Defaults to /mnt/upramdya_data/MD (the EPFL NeLy lab share) if unset.
BALLPUSHING_DATA_ROOT=/path/to/ballpushing/data

# Root directory for generated figures and stats.
# Defaults to ${BALLPUSHING_DATA_ROOT}/Affordance_Figures if unset.
BALLPUSHING_FIGURES_ROOT=/path/to/paper/figures/output
